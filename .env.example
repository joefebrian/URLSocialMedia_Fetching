# Copy this file to .env and fill in your real keys

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key_here

# X / Twitter
X_BEARER_TOKEN=your_x_bearer_token_here
# Optional full credentials (for bearer generation fallback)
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# xAI Grok
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-2

# Stripe (for premium upgrades)
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_LINK=

# Database (IMPORTANT FOR DEPLOYMENT)
# Leave empty for local SQLite. On Render/Railway etc, set this to the Postgres connection string.
DATABASE_URL=

# Optional
METRICS_REFRESH_INTERVAL=3600
NODE_ENV=production
